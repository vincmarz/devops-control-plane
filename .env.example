# DevOps Control Plane local environment example
# Copy to .env for local development only.
# Never commit .env with real values.

HTTP_ADDR=:8080
LOG_LEVEL=info

DATABASE_URL=postgres://devops_cp:devops_cp@localhost:5432/devops_control_plane?sslmode=disable

ARGOCD_BASE_URL=https://openshift-gitops-server-openshift-gitops.apps.example.local
ARGOCD_AUTH_TOKEN=<replace-me>
ARGOCD_INSECURE_TLS=false
ARGOCD_TIMEOUT_SECONDS=30
ARGOCD_POLL_INTERVAL_SECONDS=5

GITLAB_BASE_URL=https://gitlab.example.local
GITLAB_TOKEN=<replace-me>
GITLAB_PROJECT_ID=1
GITLAB_DEFAULT_BRANCH=main
GITLAB_TIMEOUT_SECONDS=30
GITLAB_INSECURE_TLS=false

TEKTON_NAMESPACE=devops-ci-demo
TEKTON_PIPELINE_NAME=go-build-and-push
TEKTON_SERVICE_ACCOUNT=pipeline
TEKTON_TIMEOUT_SECONDS=900
TEKTON_POLL_INTERVAL_SECONDS=5
TEKTON_GIT_URL=https://github.com/vincmarz/demo-go-color-app.git
TEKTON_GIT_REVISION=main
TEKTON_GIT_REVISION_TEMPLATE=
TEKTON_VALIDATION_PATH=
TEKTON_IMAGE=image-registry.openshift-image-registry.svc:5000/devops-ci-demo/demo-go-color-app:latest
TEKTON_WORKSPACE_PVC=pipeline-workspace
TEKTON_DOCKERCONFIG_SECRET=pipeline-registry-dockerconfig
KUBERNETES_API_URL=https://api.ocp4.mim.lan:6443
KUBERNETES_TOKEN=<replace-me>
KUBERNETES_INSECURE_TLS=true

KUBERNETES_NAMESPACE=devops-ci-demo
EVIDENCE_BASE_PATH=
